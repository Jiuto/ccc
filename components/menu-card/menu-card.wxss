.container {
  background: #ffffff;
  padding: 60rpx 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 20rpx 80rpx rgba(0,0,0,0.2);
  text-align: center;
  width: 90%;
  max-width: 600rpx;
}

.title {
  color: #333;
  margin-bottom: 30rpx;
  font-size: 48rpx;
  font-weight: bold;
}

.btn {
  background: linear-gradient(135deg, #606af0ff 0%, #e389f7ff 100%);
  color: white;
  border: none;
  padding: 24rpx 60rpx;
  font-size: 36rpx;
  border-radius: 60rpx;
  margin-top: 10rpx;
}

.btn::after {
  border: none;
}

.result {
  margin-top: 30rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-text {
  font-size: 40rpx;
  color: #333;
  font-weight: bold;
}

.result-hint {
  color: #999;
  font-size: 28rpx;
}

.action-btns {
  display: flex;
  gap: 20rpx;
  flex-direction: column;
  justify-content: center;
  margin-top: 30rpx;
}

.action-btns .btn {
  margin-top: 0;
  padding: 24rpx 40rpx;
  font-size: 32rpx;
  width: auto;
}

.consider-btn {
  background: linear-gradient(135deg, #606af0ff 0%, #e389f7ff 100%);
}

.confirm-btn {
  background: linear-gradient(135deg, #0bcabaff 0%, #38ef7d 100%);
}

.consider-section {
  margin-top: 40rpx;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
}

.consider-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.consider-title {
  font-size: 30rpx;
  color: #666;
  font-weight: bold;
}

.clear-btn {
  font-size: 26rpx;
  color: #0aabf0ff;
}

.consider-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.consider-item {
  display: flex;
  align-items: center;
  background: #fff;
  color: #667eea;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  border: 2rpx solid #667eea;
}

.delete-btn {
  margin-left: 12rpx;
  color: #667eea;
  font-size: 32rpx;
  font-weight: bold;
}

.final-btn {
  margin-top: 30rpx;
  background: linear-gradient(135deg, #0bcabaff 0%, #38ef7d 100%);
}

.final-result {
  margin-top: 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 20rpx;
}

.final-text {
  font-size: 38rpx;
  color: #333;
  font-weight: bold;
}

.selector-section {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.picker {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  color: #333;
  padding: 24rpx 40rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  text-align: center;
}

.view-btn {
  background: linear-gradient(135deg, #0bcabaff 0%, #38ef7d 100%);
}

.add-btn {
  background: linear-gradient(135deg, #606af0ff 0%, #e389f7ff 100%);
}

.result-section {
  margin-top: 40rpx;
}

.result-card {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 30rpx;
  padding: 40rpx;
}

.dish-name {
  font-size: 44rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.dish-type {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.dish-content {
  font-size: 30rpx;
  color: #888;
  line-height: 1.6;
  white-space: pre-wrap;
  word-wrap: break-word;
  text-align: left;
}

.selected-section {
  margin-top: 40rpx;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
}

.section-title {
  font-size: 34rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.type-group {
  margin-bottom: 24rpx;
}

.type-title {
  font-size: 30rpx;
  color: #539e85;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.dish-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
}

.dish-tag {
  background: #fff;
  color: #667eea;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  border: 2rpx solid #667eea;
}

.final-btn {
  margin-top: 35rpx;
  background: linear-gradient(135deg, #0bcabaff 0%, #38ef7d 100%);
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease-out;
}

/* 弹窗淡入动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.modal-content {
  background: white;
  border-radius: 30rpx;
  padding: 40rpx;
  width: 80%;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: 0 10rpx 60rpx rgba(254, 202, 87, 0.4);
  animation: slideUp 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
}

/* 弹窗上滑动画 */
@keyframes slideUp {
  from {
    transform: translateY(100rpx) scale(0.9);
    opacity: 0;
  }
  to {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

/* 弹窗内容动画 */
.modal-animate {
  animation: pulse 0.6s ease-in-out;
}

@keyframes pulse {
  0% {
    transform: scale(0.95);
  }
  50% {
    transform: scale(1.02);
  }
  100% {
    transform: scale(1);
  }
}

.modal-title {
  font-size: 50rpx;
  color: #feca57;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  text-shadow: 0 2rpx 8rpx rgba(138, 123, 91, 0.3);
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  animation: titleGlow 2s ease-in-out infinite alternate;
}

/* 标题图标样式 */
.title-icon {
  font-size: 56rpx;
  display: inline-block;
  animation: iconBounce 1s ease-in-out infinite;
}

/* 图标弹跳动画 */
@keyframes iconBounce {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  25% {
    transform: translateY(-8rpx) rotate(-5deg);
  }
  75% {
    transform: translateY(-8rpx) rotate(5deg);
  }
}

/* 标题发光动画 */
@keyframes titleGlow {
  from {
    text-shadow: 0 2rpx 8rpx rgba(254, 202, 87, 0.3),
                 0 0 10rpx rgba(254, 202, 87, 0.2);
  }
  to {
    text-shadow: 0 2rpx 16rpx rgba(254, 202, 87, 0.6),
                 0 0 20rpx rgba(254, 202, 87, 0.4),
                 0 0 30rpx rgba(254, 202, 87, 0.2);
  }
}

.modal-body {
  max-height: 70vh;
  overflow-y: auto;
  margin-bottom: 30rpx;
}

.dish-detail {
  background: linear-gradient(135deg, rgb(241, 209, 63) 0%, rgb(245, 151, 88));
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  animation: dishFadeIn 0.5s ease-out forwards;
  opacity: 0;
  transform: translateY(20rpx);
  box-shadow: 0 8rpx 30rpx rgba(245, 151, 88, 0.3);
}

/* 菜品卡片渐入动画 */
@keyframes dishFadeIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 为每个菜品卡片设置不同的动画延迟 */
.dish-detail:nth-child(1) { animation-delay: 0.1s; }
.dish-detail:nth-child(2) { animation-delay: 0.2s; }
.dish-detail:nth-child(3) { animation-delay: 0.3s; }
.dish-detail:nth-child(4) { animation-delay: 0.4s; }
.dish-detail:nth-child(5) { animation-delay: 0.5s; }

.detail-name {
  font-size: 42rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.detail-type {
  font-size: 30rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
}

.detail-content {
  font-size: 30rpx;
  color: white;
  line-height: 1.5;
  white-space: pre-wrap;
  word-wrap: break-word;
  text-align: left;
}

.close-btn {
  background: linear-gradient(135deg, rgb(150, 155, 233) 0%, #e389f7ff 100%);
}

.copy-icon {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 40rpx;
  cursor: pointer;
  opacity: 0.6;
  transition: all 0.3s ease;
  z-index: 10;
}

.copy-icon:active {
  opacity: 1;
  transform: scale(0.9);
}

.back-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #f4f5f5 0%, #9bb8d8 100%);
}
