<view class="container">
  <view class="title">喝不喝</view>
  <view class="sub-title1">这是一个问题</view>
  <view class="sub-title2">我是说奶茶</view>

  <view class="input-container">
    <text class="input-label">这周已喝：</text>
    <input class="input-number" value="{{weekDrinkCount}}" bindinput="onInput" />
    <text class="input-unit">瓶</text>
  </view>

  <view class="probability-display" wx:if="{{weekDrinkCount}}">
    <text class="info-icon" bindtap="showInfoModal">💡</text>
    <text class="probability-label">成功率：</text>
    <text class="probability-value">{{probabilityText}}</text>
  </view>

  <button class="btn" bindtap="randomPick">来吧！</button>

  <!-- 类型选择器 -->
  <view class="type-selector" wx:if="{{showTypeSelector}}">
    <view class="selector-header">
      <text class="selector-title">那喝什么呢？</text>
    </view>
    
    <view class="selector-body">
      <view class="picker-container">
        <picker class="type-picker" value="{{selectedTypeIndex}}" range="{{typeOptions}}" bindchange="onTypeChange">
          <view class="picker-display">
            <text class="selected-text">{{typeOptions[selectedTypeIndex]}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <button class="btn" bindtap="randomSelectDrink">随机选择</button>

    </view>
  </view>

  <!-- 自定义提示框 -->
  <view class="custom-toast {{showToast ? 'show' : ''}}" wx:if="{{showToast}}">
    <text class="custom-toast-text">{{toastMessage}}</text>
  </view>

  <!-- 说明弹窗 -->
  <view class="modal-mask {{showInfoModal ? 'show' : ''}}" wx:if="{{showInfoModal}}" bindtap="hideInfoModal">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">成功率计算规则</text>
        <text class="modal-close" bindtap="hideInfoModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="rule-section">
          <text class="rule-title">📅 周一到周三</text>
          <text class="rule-desc">• 本周未喝：60%</text>
          <text class="rule-desc">• ≤ 0.5 瓶：50%</text>
          <text class="rule-desc">• 0.5-1 瓶：40%</text>
          <text class="rule-desc">• > 1 瓶：30%</text>
        </view>
        <view class="rule-section">
          <text class="rule-title">📅 周四到周五</text>
          <text class="rule-desc">• ≤ 1 瓶：70%</text>
          <text class="rule-desc">• 1-2 瓶：50%</text>
          <text class="rule-desc">• > 2 瓶：30%</text>
        </view>
        <view class="rule-section">
          <text class="rule-title">📅 周六、周日</text>
          <text class="rule-desc">• ≤ 2 瓶：70%</text>
          <text class="rule-desc">• 2-3 瓶：40%</text>
          <text class="rule-desc">• > 3 瓶：10%</text>
        </view>
      </view>
    </view>
  </view>
</view>
