.container {
  background: #ffffff;
  padding: 60rpx 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 20rpx 80rpx rgba(0,0,0,0.2);
  text-align: center;
  width: 90%;
  max-width: 600rpx;
}

.title {
  color: #333;
  margin-bottom: 30rpx;
  font-size: 48rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-btn {
  font-size: 40rpx;
  margin-right: 16rpx;
  cursor: pointer;
  transition: transform 0.2s ease;
}

.info-btn:active {
  transform: scale(0.8);
}

.select-wrapper {
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.label {
  color: #666;
  font-size: 32rpx;
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.picker {
  width: 400rpx;
  padding: 24rpx 30rpx;
  font-size: 32rpx;
  border: 4rpx solid #ddd;
  border-radius: 20rpx;
  background: #fff;
  color: #333;
  text-align: center;
}

.btn {
  background: linear-gradient(135deg, #606af0ff 0%, #e389f7ff 100%);
  color: white;
  border: none;
  padding: 24rpx 60rpx;
  font-size: 36rpx;
  border-radius: 60rpx;
  margin-top: 10rpx;
}

.btn::after {
  border: none;
}

.result {
  margin-top: 30rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-text {
  font-size: 40rpx;
  color: #333;
  font-weight: bold;
}

.result-hint {
  color: #999;
  font-size: 28rpx;
}

.action-btns {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-top: 30rpx;
}

.action-btns .btn {
  margin-top: 0;
  padding: 24rpx 40rpx;
  font-size: 32rpx;
  width: auto;
}

.consider-btn {
  background: linear-gradient(135deg, #606af0ff 0%, #e389f7ff 100%);
}

.confirm-btn {
  background: linear-gradient(135deg, #0bcabaff 0%, #38ef7d 100%);
}

.consider-section {
  margin-top: 40rpx;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 20rpx;
}

.consider-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.consider-title {
  font-size: 30rpx;
  color: #666;
  font-weight: bold;
}

.clear-btn {
  font-size: 26rpx;
  color: #0aabf0ff;
}

.consider-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.consider-item {
  display: flex;
  align-items: center;
  background: #fff;
  color: #667eea;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  border: 2rpx solid #667eea;
}

.delete-btn {
  margin-left: 12rpx;
  color: #667eea;
  font-size: 36rpx;
  font-weight: bold;
}

.final-btn {
  margin-top: 30rpx;
  background: linear-gradient(135deg, #0bcabaff 0%, #38ef7d 100%);
}

.final-result {
  margin-top: 30rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 20rpx;
}

.final-text {
  font-size: 38rpx;
  color: #333;
  font-weight: bold;
}

/* 选项说明弹窗 */
.info-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.info-modal-overlay.show {
  opacity: 1;
}

.info-modal-content {
  background: white;
  padding: 50rpx 40rpx;
  border-radius: 30rpx;
  width: 85%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 80rpx rgba(0, 0, 0, 0.3);
  animation: modalBounceIn 0.5s ease;
}

.modal-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
}

.modal-emoji {
  font-size: 60rpx;
  margin-top: 10rpx;
}

.type-section {
  margin-bottom: 30rpx;
  text-align: left;
}

.type-section:last-child {
  margin-bottom: 20rpx;
}

.type-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 15rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #667eea;
}

.option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.option-item {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid #dee2e6;
  font-size: 26rpx;
  color: #495057;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
}

.option-item.selected {
  background: linear-gradient(135deg, #e8eaff 0%, #f3d6fd 100%);
  border-color: #667eea;
  color: #667eea;
  font-weight: bold;
}

.option-check {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
  margin-left: 4rpx;
}

.option-item:active {
  transform: scale(0.95);
  border-color: #667eea;
}

.modal-close-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #606af0ff 0%, #e389f7ff 100%);
}

@keyframes modalBounceIn {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}
