<!--index.wxml-->
<view class="page-container">
  <!-- 顶部提示信息 -->
  <view class="top-tip" wx:if="{{showTopTip}}">
    <text class="tip-icon">💡💾</text>
    <text class="tip-text">可点击，该小程序所有选项均为续宝量身定制</text>
    <text class="tip-close" bindtap="closeTopTip">✕</text>
  </view>

  <swiper class="card-swiper" indicator-dots="{{true}}" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#ffffff">
    <!-- 卡片1: 今天吃什么 -->
    <swiper-item>
      <scroll-view class="card-scroll" scroll-y="{{true}}">
        <food-card bind:celebrate="onCelebrate" />
      </scroll-view>
    </swiper-item>

    <!-- 卡片2: 做点什么呢 -->
    <swiper-item>
      <scroll-view class="card-scroll" scroll-y="{{true}}">
        <activity-card bind:celebrate="onCelebrate" />
      </scroll-view>
    </swiper-item>

    <!-- 卡片3: 喝不喝 -->
    <swiper-item>
      <scroll-view class="card-scroll" scroll-y="{{true}}">
        <drunk-card bind:celebrate="onCelebrate" />
      </scroll-view>
    </swiper-item>

    <!-- 卡片4: 买水果 -->
    <swiper-item>
      <scroll-view class="card-scroll" scroll-y="{{true}}">
        <fruit-card bind:celebrate="onCelebrate" />
      </scroll-view>
    </swiper-item>

    <!-- 卡片5: 菜谱 -->
    <swiper-item>
      <scroll-view class="card-scroll" scroll-y="{{true}}">
        <menu-card bind:celebrate="onCelebrate" />
      </scroll-view>
    </swiper-item>
  </swiper>

  <!-- 选中特效 -->
  <view class="celebrate-overlay {{showCelebrate ? 'show' : ''}}" wx:if="{{showCelebrate}}">
    <view class="celebrate-content">
      <view class="celebrate-emoji">{{isSadStyle ? '🌧️' : '🎉'}}</view>
      <view class="celebrate-result {{isSadStyle ? 'sad-result' : ''}}">{{confirmedResult}}</view>
      <view class="celebrate-emoji2">{{celebrateEmoji}}</view>
      <view class="sparkles" wx:if="{{!isSadStyle}}">
        <text class="sparkle s1">✨</text>
        <text class="sparkle s2">⭐</text>
        <text class="sparkle s3">✨</text>
        <text class="sparkle s4">🌟</text>
        <text class="sparkle s5">✨</text>
      </view>
      <!-- 悲伤特效 -->
      <view class="sad-effects" wx:if="{{isSadStyle}}">
        <text class="raindrop r1">💧</text>
        <text class="raindrop r2">💧</text>
        <text class="raindrop r3">💧</text>
        <text class="raindrop r4">💧</text>
        <text class="raindrop r5">💧</text>
      </view>
    </view>
    <button class="btn close-celebrate-btn {{isSadStyle ? 'sad-btn' : ''}}" bindtap="closeCelebrate">{{isSadStyle ? '好叭！' : '好的！'}}</button>
  </view>
</view>
