/**index.wxss**/
page {
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  justify-content: center;
  align-items: center;
}

.page-container {
  width: 100%;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
  position: relative;
}

/* 顶部提示信息 */
.top-tip {
  position: fixed;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
  animation: slideDown 0.5s ease-out;
}

.tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.4;
  flex: 1;
}

.tip-close {
  font-size: 36rpx;
  color: #999;
  flex-shrink: 0;
  cursor: pointer;
  transition: all 0.2s;
  line-height: 1;
}

.tip-close:active {
  color: #ff4444;
  transform: scale(0.9);
}

.card-swiper {
  width: 100%;
  height: 100vh;
}

.card-swiper swiper-item {
  height: 100%;
  box-sizing: border-box;
}

.card-scroll {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.card-scroll food-card,
.card-scroll activity-card,
.card-scroll drunk-card,
.card-scroll fruit-card,
.card-scroll menu-card
{
  display: flex;
  justify-content: center;
  min-height: 100%;
  align-items: center;
  padding: 40rpx 0;
  box-sizing: border-box;
}

/* 庆祝特效 */
.celebrate-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.3s ease-out;
}

.celebrate-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: bounceIn 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.celebrate-emoji {
  font-size: 120rpx;
  animation: bounce 1s infinite;
}

.celebrate-emoji2 {
  font-size: 80rpx;
  margin-top: 20rpx;
  animation: swing 1s infinite;
}

.celebrate-result {
  font-size: 72rpx;
  font-weight: bold;
  color: #feca57;
  margin-top: 20rpx;
  text-shadow: 0 0 30rpx rgba(254, 202, 87, 0.8);
  animation: pulse 1.5s infinite;
}

/* 悲伤风格结果 */
.sad-result {
  color: #5f6c7b;
  text-shadow: 0 0 30rpx rgba(95, 108, 123, 0.6);
  animation: sadPulse 1.5s infinite;
}

.sparkles {
  position: absolute;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.sparkle {
  position: absolute;
  font-size: 60rpx;
  animation: sparkle 2s infinite;
}

.s1 { top: 15%; left: 10%; animation-delay: 0s; }
.s2 { top: 20%; right: 15%; animation-delay: 0.3s; }
.s3 { top: 60%; left: 8%; animation-delay: 0.6s; }
.s4 { top: 70%; right: 10%; animation-delay: 0.9s; }
.s5 { top: 40%; left: 50%; animation-delay: 1.2s; }

/* 悲伤特效 */
.sad-effects {
  position: absolute;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.raindrop {
  position: absolute;
  font-size: 50rpx;
  animation: rainDrop 1.5s infinite;
}

.r1 { top: 10%; left: 15%; animation-delay: 0s; }
.r2 { top: 15%; right: 20%; animation-delay: 0.3s; }
.r3 { top: 50%; left: 10%; animation-delay: 0.6s; }
.r4 { top: 55%; right: 15%; animation-delay: 0.9s; }
.r5 { top: 75%; left: 50%; animation-delay: 1.2s; }

.btn {
  background: linear-gradient(135deg, #606af0ff 0%, #e389f7ff 100%);
  color: white;
  border: none;
  padding: 24rpx 60rpx;
  font-size: 36rpx;
  border-radius: 60rpx;
  margin-top: 10rpx;
}

.btn::after {
  border: none;
}

.close-celebrate-btn {
  margin-top: 80rpx;
  background: linear-gradient(135deg, rgb(247, 203, 8) 0%, rgb(247, 152, 89) 100%);
  animation: fadeInUp 0.5s ease-out 0.3s both;
}

/* 悲伤风格按钮 */
.sad-btn {
  background: linear-gradient(135deg, #5f6c7b 0%, #7a8b99 100%);
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes bounceIn {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

@keyframes swing {
  0%, 100% { transform: rotate(-10deg); }
  50% { transform: rotate(10deg); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes sparkle {
  0%, 100% { opacity: 0; transform: scale(0.5) rotate(0deg); }
  50% { opacity: 1; transform: scale(1.2) rotate(180deg); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes sadPulse {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(0.95); opacity: 1; }
}

@keyframes rainDrop {
  0% { opacity: 0; transform: translateY(-20rpx); }
  50% { opacity: 1; }
  100% { opacity: 0; transform: translateY(20rpx); }
}

@keyframes cloudFloat {
  0%, 100% { transform: translateX(-50%) rotate(0deg); }
  50% { transform: translateX(-50%) rotate(5deg); }
}

@keyframes slideDown {
  from { 
    opacity: 0;
    transform: translateY(-100rpx);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}
